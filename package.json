{
  "name": "mcp-local-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local homelab MCP tool gateway for shell, file, patch, and log workflows.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:stdio": "tsx src/stdio.ts",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:stdio": "node dist/stdio.js",
    "test": "vitest run",
    "test:local": "bash scripts/local-validate.sh",
    "service:install": "bash scripts/install-user-service.sh",
    "service:uninstall": "bash scripts/uninstall-user-service.sh",
    "service:status": "systemctl --user status mcp-local-gateway --no-pager",
    "service:logs": "journalctl --user -u mcp-local-gateway -n 100 --no-pager",
    "tunnel:install": "bash scripts/install-openai-tunnel-service.sh",
    "tunnel:uninstall": "bash scripts/uninstall-openai-tunnel-service.sh",
    "tunnel:status": "systemctl --user status openai-tunnel-client.service --no-pager",
    "tunnel:logs": "journalctl --user -u openai-tunnel-client.service -n 100 --no-pager"
  },
  "dependencies": {
    "@cfworker/json-schema": "4.1.1",
    "@hono/node-server": "2.0.5",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "dotenv": "17.4.2",
    "hono": "4.12.26",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
